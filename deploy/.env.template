#
# NDASA Donation Platform — production .env
#
# Copy to public_html/.ndasa-donation/.env on the server, fill in the
# placeholders marked with REPLACE_ME, then chmod 600. Never commit this
# file with real values.
#

APP_ENV=production
APP_URL=https://ndasafoundation.org/donation
APP_TIMEZONE=America/New_York

# ——— Stripe ———
# Get the fresh key from https://dashboard.stripe.com/apikeys (Live mode).
# Webhook secret comes from the endpoint you create in Developers -> Webhooks.
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ——— SMTP (Rackspace Email) ———
# Shared with WordPress via the ndasa-shared-env mu-plugin.
SMTP_HOST=secure.emailsrvr.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USERNAME=admin@ndasafoundation.org
SMTP_PASSWORD=REPLACE_ME

MAIL_FROM=admin@ndasafoundation.org
MAIL_FROM_NAME="NDASA Foundation"
MAIL_BCC_INTERNAL=donations@ndasafoundation.org

# ——— Storage ———
# Absolute path. Lives inside .ndasa-donation/storage/, out of the webroot.
# The installer fills this in automatically for the detected chroot.
DB_PATH=/chroot/home/a64cc811/c4edf90fcd.nxcli.io/html/.ndasa-donation/storage/donations.sqlite

# ——— Sessions ———
SESSION_NAME=ndasa_sess

# ——— Donation bounds (in cents) ———
DONATION_MIN_CENTS=1000
DONATION_MAX_CENTS=1000000

# ——— Trusted proxies ———
# Nexcess runs nginx in front of Apache/PHP-FPM internally; traffic arriving
# at PHP already has REMOTE_ADDR set to the real client by the platform.
# Leave empty unless you add your own CDN (Cloudflare, etc.) in front.
TRUSTED_PROXIES=
