<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         bootstrap="vendor/autoload.php"
         colors="true"
         cacheDirectory=".phpunit.cache">
    <testsuites>
        <testsuite name="default">
            <directory suffix="Test.php">tests</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>src</directory>
        </include>
    </source>
    <!-- Route production error_log() calls out of STDERR so the normal
         "app swallowed and logged this" messages don't clutter test output.
         Critical: this is PHP's error_log sink, not PHPUnit's assertion
         output. Test failures still surface normally. -->
    <php>
        <ini name="error_log" value="/dev/null"/>
        <ini name="log_errors" value="On"/>
        <ini name="display_errors" value="Off"/>
    </php>
</phpunit>
