APP_ENV=production
APP_URL=https://ndasafoundation.org
APP_TIMEZONE=America/New_York

# Stripe: use test keys for local/staging (sk_test_...), live keys only in production.
# Do NOT commit real values. Keep .env chmod 600, owned by the web user.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
# Generated when you register the webhook endpoint in the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# SMTP — set EITHER the discrete components below OR a pre-formed SMTP_DSN.
# Components are preferred because they're safe with any password charset
# (no URL-encoding needed). If both are set, SMTP_DSN wins.
SMTP_HOST=secure.emailsrvr.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls         # "tls" = STARTTLS on 587, "ssl" = implicit TLS on 465
SMTP_USERNAME=admin@ndasafoundation.org
SMTP_PASSWORD=replace-me
# SMTP_DSN=smtp://user:pass@smtp.example.com:587   # optional override

MAIL_FROM=admin@ndasafoundation.org
MAIL_FROM_NAME="NDASA Foundation"
MAIL_BCC_INTERNAL=donations@ndasafoundation.org

SESSION_NAME=ndasa_sess

# Absolute path. Must be outside the webroot and writable by the web user.
DB_PATH=/var/www/ndasa-donation/storage/donations.sqlite

# Donation bounds in cents ($10 .. $10,000).
DONATION_MIN_CENTS=1000
DONATION_MAX_CENTS=1000000

# Comma-separated IPs / CIDRs of reverse proxies whose X-Forwarded-For we trust.
# Leave empty if the app is not behind a proxy. Never set to a wildcard.
# Example: 10.0.0.0/8,173.245.48.0/20
TRUSTED_PROXIES=
