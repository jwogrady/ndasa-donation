# NDASA Donation Platform — example environment
#
# Copy to `.env`, fill in real values, and chmod 600.
#
# `.env` is SSH-only — the admin UI at /admin/diagnostics is read-only.
# Every key marked REQUIRED must be non-empty or the bootstrap aborts
# with HTTP 500.

# ── App ────────────────────────────────────────────────────────────────────
# APP_ENV: "production" enforces HTTPS redirects and sets secure-cookie mode.
# Any other value (e.g. "local") disables those checks for local/staging.
APP_ENV=local
APP_URL=http://localhost:8000                 # REQUIRED. Include any subpath.
APP_TIMEZONE=America/New_York

# Explicit version string shown in the admin footer. Takes priority over
# the short git hash (.git/HEAD) and the hardcoded fallback constant.
APP_VERSION=1.1.0

# ── Stripe ─────────────────────────────────────────────────────────────────
# The app supports two modes — "live" and "test" — toggled from
# /admin/diagnostics. Populate both pairs if you want runtime mode switching;
# the live pair alone is enough for a production-only install.
#
# Legacy STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET are still honored as a
# fallback for LIVE mode when STRIPE_LIVE_* are unset — keeps older installs
# working without an .env rewrite.
STRIPE_LIVE_SECRET_KEY=sk_live_REPLACE_ME         # REQUIRED (or legacy STRIPE_SECRET_KEY)
STRIPE_LIVE_WEBHOOK_SECRET=whsec_REPLACE_ME       # REQUIRED (or legacy STRIPE_WEBHOOK_SECRET)
STRIPE_TEST_SECRET_KEY=sk_test_REPLACE_ME         # Optional; required to flip into test mode
STRIPE_TEST_WEBHOOK_SECRET=whsec_REPLACE_ME       # Optional; required to flip into test mode

# ── Database ───────────────────────────────────────────────────────────────
# Absolute path. Must be outside the webroot and writable by the web user.
DB_PATH=/var/www/ndasa-donation/storage/donations.sqlite   # REQUIRED

# ── Donation limits (cents) ────────────────────────────────────────────────
DONATION_MIN_CENTS=1000                        # $10
DONATION_MAX_CENTS=1000000                     # $10,000

# ── Networking ─────────────────────────────────────────────────────────────
# Comma-separated IPs / CIDRs of reverse proxies whose X-Forwarded-For we
# trust. Leave empty if the app is not behind a proxy. Never use a wildcard.
# Example: 10.0.0.0/8,173.245.48.0/20
TRUSTED_PROXIES=

# ── Sessions ───────────────────────────────────────────────────────────────
SESSION_NAME=ndasa_sess

# ── Admin panel (HTTP Basic Auth) ──────────────────────────────────────────
# If either is empty, every /admin* route returns 500 rather than exposing
# the panel unauthenticated. These are NOT editable from the admin UI —
# rotate from the shell.
ADMIN_USER=admin
ADMIN_PASS=replace-me
